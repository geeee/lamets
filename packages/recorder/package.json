{
  "name": "lamets-recorder",
  "version": "0.1.0",
  "description": "Record MP3 audio from the microphone in the browser using lamets",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mp3",
    "recorder",
    "microphone",
    "web-audio",
    "browser",
    "lamets",
    "audio-recording"
  ],
  "license": "LGPL-2.1-or-later",
  "dependencies": {
    "lamets": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
