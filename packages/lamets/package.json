{
  "name": "lamets",
  "version": "0.1.0",
  "description": "Fast MP3 encoder in TypeScript — encode PCM to MP3 in the browser or Node.js, no native deps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mp3",
    "mp3-encoder",
    "encoder",
    "lame",
    "lamejs",
    "audio",
    "pcm-to-mp3",
    "wav-to-mp3",
    "web-audio",
    "browser",
    "typescript",
    "esm"
  ],
  "license": "LGPL-2.1-or-later",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
